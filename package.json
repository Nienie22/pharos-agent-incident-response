{
  "name": "pharos-agent-incident-response",
  "version": "0.1.0",
  "description": "CLI for Pharos agent incident response workflows.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pharos-incident": "bin/cli.js"
  },
  "files": [
    "bin/cli.js",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nienie22/pharos-agent-incident-response.git"
  },
  "bugs": {
    "url": "https://github.com/Nienie22/pharos-agent-incident-response/issues"
  },
  "homepage": "https://github.com/Nienie22/pharos-agent-incident-response#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "incident": "node bin/cli.js",
    "contracts:build": "node scripts/run-forge.mjs build",
    "contracts:test": "node scripts/run-forge.mjs test",
    "isolation-check": "node scripts/isolation-check.mjs",
    "secret-scan": "node scripts/secret-scan.mjs",
    "deploy:atlantic": "node scripts/deploy-atlantic.mjs",
    "acceptance:atlantic": "node scripts/atlantic-acceptance.mjs",
    "build:api-vercel": "node scripts/build-api-vercel.mjs"
  },
  "dependencies": {
    "@pharos-incident/sdk": "^0.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4"
  }
}
